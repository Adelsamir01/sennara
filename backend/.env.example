# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Security
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sennara_dev

# PostgreSQL Pool Tuning
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# Redis
REDIS_URL=redis://localhost:6379/0

# S3 / MinIO Object Storage
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=sennara-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# AWS (optional - only if using real S3 instead of MinIO)
AWS_REGION=eu-west-1
AWS_S3_BUCKET=
AWS_CLOUDFRONT_DOMAIN=

# OTP / SMS (SMSMISR primary, Twilio fallback)
SMSMISR_USERNAME=
SMSMISR_PASSWORD=
SMSMISR_SENDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Social login
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Payments
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_WALLET=
PAYTABS_PROFILE_ID=
PAYTABS_SERVER_KEY=
INSTAPAY_CLIENT_ID=
INSTAPAY_CLIENT_SECRET=

# Marine weather (open-meteo is free/no key; StormGlass requires key)
STORMGLASS_API_KEY=
WEATHER_CACHE_TTL_SECONDS=1800

# Backups
BACKUP_DIR=/backups
